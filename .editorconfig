root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Google Java Style Guide settings
[*.java]
indent_style = space
indent_size = 2
tab_width = 2
max_line_length = 100
continuation_indent_size = 4
block_comment_start = /*
block_comment = *
block_comment_end = */

# Build files
[*.{gradle,groovy}]
indent_style = space
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = off
